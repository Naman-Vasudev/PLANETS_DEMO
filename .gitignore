# Root .gitignore for EXOPLANET HUNTERS Project

# Virtual Environments
venv_compat/
venv/
env/
.venv/
ENV/

# Python Cache & Compiled Files
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build Outputs
build/
dist/
out/
.next/

# IDEs & System
.vscode/
.idea/
.project
.pydevproject
.settings/
.DS_Store
Thumbs.db

# Environment Variables & Secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# Diagnostic & Temp Files
scratch/
temp/
*.log
task-*.log

# PowerPoint presentations
*.pptx
