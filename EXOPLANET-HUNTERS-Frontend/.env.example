# ── Exoplanet Hunters Frontend Environment Variables ──────────────────────────
# Copy this file to .env.local and fill in your values.
# On Vercel: set these in the project dashboard under Settings > Environment Variables

# Backend API URL — replace with your Render.com service URL after deploying
# Example: REACT_APP_API_URL=https://exoplanet-hunters-api.onrender.com/api/v1
REACT_APP_API_URL=https://YOUR_RENDER_SERVICE_NAME.onrender.com/api/v1
REACT_APP_API_TIMEOUT=60000

# NASA API
REACT_APP_NASA_WMTS_URL=https://gibs.earthdata.nasa.gov/wmts/epsg4326/best
REACT_APP_NASA_API_KEY=MsAjcbAtRnJLxgitGTx2Xo2JXgaDfcfpTnJOhJBQ

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_AUTH=true
REACT_APP_ENABLE_3D_MODELS=true
